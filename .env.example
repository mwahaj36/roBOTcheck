# roBOTcheck Server Configuration Example
# Copy this file to .env and configure the variables before launching the server in production mode.

PORT=3000
NODE_ENV=production

# The public sitekey used in the frontend widget mounting element
SITEKEY=rc_pub_your_sitekey_here

# The secret API key used by the developer's backend server to verify challenge tokens
SECRETKEY=rc_sec_your_secret_key_here

# A long random cryptographically secure key used internally to sign session and result JWTs
SECRET=your_long_cryptographic_signing_secret_here

# Comma-separated list of origins allowed to request challenges (used for CORS verification)
ALLOWED_ORIGINS=http://localhost:4000
